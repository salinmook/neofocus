<div class="instructions-page">
  <h1 class="instructions-title">How to Play</h1>
  <p class="instructions-subtitle">Find the Lone Figure</p>

  <div class="instruction-content text-center mb-1 px-2">
    <div class="image-box border-2 border-dark rounded-3 shadow-sm bg-white overflow-hidden">
      <%= image_tag "instruction-rec.png", class: "img-fluid" %>
    </div>
  </div>

  <ol class="instructions-steps">
    <li><strong>SPOT</strong> — The unique shape.</li>
    <li><strong>CLICK</strong> — To get points.</li>
    <li><strong>COLLECT</strong> — See how many you can get!</li>
  </ol>

  <% if local_assigns [:in_modal] %>
    <button class="btn-enter" data-bs-dismiss="modal">GOT IT!</button>
  <% else %>
    <%= link_to "GOT IT!", menu_path, class: "btn-enter" %>
  <% end %>
</div>
