<div class="auth-page">
  <h1 class="auth-title">Welcome 👋</h1>
  <p class="auth-subtitle">Log in to continue</p>

  <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="auth-form">
      <%= f.input :email,
                  required: false,
                  autofocus: true,
                  label: "Email",
                  input_html: { autocomplete: "email", class: "auth-input" } %>
      <%= f.input :password,
                  required: false,
                  label: "Password",
                  input_html: { autocomplete: "current-password", class: "auth-input" } %>
      <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
    </div>

    <div class="form-actions">
      <%= f.button :submit, "Log in", class: "btn-enter" %>
    </div>
  <% end %>

  <div class="auth-links">
    <%= render "devise/shared/links" %>
  </div>
</div>
